{
  "meta": {
    "name": "Reflct OS Design Tokens",
    "style": "retro-OS Y2K / vaporwave",
    "source": "docs/design-reference/README.md (handoff hifi) — palette e componenti canonici del progetto",
    "note": "Palette/estetica presa dallo handoff 'Y2K tryonfeed' (finestre stile Win9x). Le 9 schermate e il feature-set vengono dal Concept v4.0 (docs/concept), ma reskinnate con questi token."
  },
  "color": {
    "desktop": "#9FE0CC",
    "desktop2": "#7FD4BE",
    "win": "#FBDCE8",
    "winAlt": "#DCF3EC",
    "chrome": "#F49AC1",
    "chrome2": "#6FCBB6",
    "ink": "#2A2438",
    "ink2": "#5A4E6E",
    "muted": "#8A7FA0",
    "pink": "#FF5FA2",
    "cyan": "#4FD3E6",
    "mint": "#2FAF8E",
    "yellow": "#F5D14E",
    "lav": "#C6A5F2",
    "warn": "#F5A03D",
    "white": "#FFFFFF"
  },
  "typography": {
    "fontFamily": {
      "pixel": "Press Start 2P",
      "chrome": "Silkscreen",
      "body": "VT323",
      "title": "Pixelify Sans"
    },
    "usage": {
      "pixel": "logo, nome utente, numeri grandi/percentuali (8-20px)",
      "chrome": "chrome finestre, tab, badge, brand, taskbar, valori lista (7-11px), pesi 400/700",
      "body": "testo corpo, prezzi, righe lista, orologio (14-22px)",
      "title": "titoli capi, titoli dialog, label sezione (15-18px), pesi 600/700"
    }
  },
  "border": {
    "width": "2px",
    "color": "#2A2438",
    "radius": {
      "window": "4px",
      "folderSwatch": "5px",
      "button": "3px",
      "titleBar": "2px"
    }
  },
  "shadow": {
    "window": "3px 3px 0 #2A2438",
    "windowHover": "5px 5px 0 #2A2438",
    "button": "2px 2px 0 #2A2438",
    "buttonHover": "4px 4px 0 #2A2438",
    "buttonActive": "0 0 0 #2A2438",
    "rule": "SOLO offset solido, MAI blur"
  },
  "motion": {
    "cardHover": "translate(-1px,-2px)",
    "buttonHover": "translate(-1px,-1px)",
    "buttonActive": "translate(2px,2px)",
    "likeHover": "rotate(-4deg) scale(1.08)",
    "swatchHover": "translate(-1px,-1px)",
    "taskbarIconHover": "translateY(-2px)",
    "duration": "0.12s-0.16s",
    "easing": "ease",
    "rule": "Nessuna animazione temporizzata/looping, solo transizioni su interazione"
  },
  "spacing": {
    "blockGap": "12px",
    "windowPadding": "12-13px",
    "masonryColumnGap": "12px",
    "folderGridGap": "8px"
  },
  "collage": {
    "rotationRange": ["-1.4deg", "1.4deg"],
    "cssVar": "--rot"
  },
  "components": [
    "win", "win--mint", "win--pop", "win-title", "win-title--teal", "win-btns",
    "btn-95", "btn-95--cta", "btn-95--cyan", "btn-95--yellow", "btn-95--block",
    "tab", "stamp", "size-pill", "swatch", "fitbar", "row", "folder",
    "masonry-2", "filter-strip", "heart-meter", "taskbar-item", "shot", "shot__tag",
    "menubar", "h-pix", "label-hand"
  ],
  "screens": [
    { "id": "onboarding", "title": "onboarding.exe", "origin": "concept-v4 (nuova, reskin retro-OS)" },
    { "id": "feed", "title": "home.exe / wardrobe.exe", "origin": "handoff hifi" },
    { "id": "tryon", "title": "tryon.exe — cabina di prova", "origin": "handoff hifi" },
    { "id": "import", "title": "import.exe", "origin": "concept-v4 (nuova, reskin retro-OS)" },
    { "id": "wardrobe", "title": "wardrobe.dat — il mio armadio", "origin": "handoff hifi" },
    { "id": "social", "title": "battle.net — social", "origin": "concept-v4 (nuova, reskin retro-OS)" },
    { "id": "share", "title": "share.exe", "origin": "concept-v4 (nuova, reskin retro-OS)" },
    { "id": "priceTracker", "title": "pricewatch.sys", "origin": "concept-v4 (nuova, reskin retro-OS)" },
    { "id": "profile", "title": "profile.sys / measures.cfg / settings.ini", "origin": "handoff hifi" }
  ],
  "nav": [
    { "key": "Feed", "icon": "🖥", "label": "FEED" },
    { "key": "Prova", "icon": "🪞", "label": "PROVA" },
    { "key": "Armadio", "icon": "🗄", "label": "ARMADIO" },
    { "key": "Io", "icon": "💾", "label": "IO" }
  ]
}
