# Copia in .env e personalizza. Expo inlinea a build-time le variabili con
# prefisso EXPO_PUBLIC_ (vedi src/api/client.ts).
#
# "localhost" dal punto di vista del telefono/emulatore NON e' la macchina di
# sviluppo:
#   - Android emulator -> usa 10.0.2.2 al posto di localhost
#   - iOS simulator    -> localhost funziona (stessa rete host)
#   - device fisico    -> usa l'IP LAN del computer (es. 192.168.1.23)
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
