# Copia questo file in infra/.env e personalizza i valori prima di
# `docker compose up --build`. Nessun segreto reale qui dentro.

# --- PostgreSQL ---
POSTGRES_DB=reflct
POSTGRES_USER=reflct
POSTGRES_PASSWORD=reflct

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=reflct
MINIO_ROOT_PASSWORD=reflct12345

# --- backend-api (Spring Boot) ---
JWT_SECRET=change-me-to-a-long-random-string-in-production-0123456789
CORS_ALLOWED_ORIGINS=http://localhost:8080

# --- porte esposte sull'host (modificabili in caso di conflitto locale) ---
WEB_PORT=8080
API_PORT=8090
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AI_SERVICE_PORT=8001
SCRAPING_SERVICE_PORT=8002
